# DigiReps Electron App — Environment Variables
# ─────────────────────────────────────────────────────────────────
# HOW TO USE:
#   Local dev:      This file is loaded automatically by Vite
#   Production:     Set VITE_API_BASE_URL to your Railway backend URL
#                   then run: npm run build:electron
# ─────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://lgmggbnaoyoapxqsfgzv.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Backend API ──────────────────────────────────────────────────
# Local dev:
VITE_API_BASE_URL=http://localhost:3001
# Production (uncomment and change to your Railway URL):
# VITE_API_BASE_URL=https://your-backend.up.railway.app

# ── Admin Portal ─────────────────────────────────────────────────
# Used for the "Forgot Password" redirect link
VITE_ADMIN_PORTAL_URL=http://localhost:5174
# Production:
# VITE_ADMIN_PORTAL_URL=https://admin.yourapp.com
