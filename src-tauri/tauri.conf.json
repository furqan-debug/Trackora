{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrackOwl",
  "version": "1.2.4",
  "identifier": "com.digireps.tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TrackOwl",
        "width": 440,
        "height": 700,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https://*; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://lgmggbnaoyoapxqsfgzv.supabase.co *.supabase.co https://*; font-src 'self' data: https://*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "DigiReps",
    "copyright": "Copyright © 2026 DigiReps",
    "shortDescription": "TrackOwl Time Tracker",
    "longDescription": "Efficient time tracking for DigiReps teams.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/furqan-debug/TrackOwl/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgwMEY2QUE2MzI3MDgwMDIKa0Z0Z01HSXpDV0xvbHJ0aWxhVzYxeGdEUE1vc0I5Ymt6d0FzR1R3ZkR1WW1adUpjUll1NFhpdlQK"
    },
    "notification": null
  }
}