{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trackora",
  "version": "1.0.1",
  "identifier": "com.digireps.tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Trackora",
        "width": 440,
        "height": 700,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "DigiReps",
    "copyright": "Copyright © 2026 DigiReps",
    "shortDescription": "Trackora Time Tracker",
    "longDescription": "Efficient time tracking for DigiReps teams.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/furqan-debug/Trackora/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1OEFCMEVCM0Q1QjQyRTQKUldUa1Fsczk2N0NLdFkzeERHMXJGUk1KNkt0b0FsY3VTeVIyaFd1Vy9hM2xndVdzdEdTSFFHRHgK"
    }
  }
}