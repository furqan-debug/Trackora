# DigiReps Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────
# HOW TO USE:
#   Local dev:   Copy this to backend/.env and fill in the values
#   Railway:     Add these as Environment Variables in Railway dashboard
# ─────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://lgmggbnaoyoapxqsfgzv.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── Server ───────────────────────────────────────────────────────
# Railway sets PORT automatically — don't change this line
PORT=3001

# ── URLs (update these after deployment) ─────────────────────────
# The deployed URL of your admin portal (e.g. https://admin.digireps.app)
# Used in invite emails and CORS allowlist
ADMIN_PORTAL_URL=http://localhost:5174

# The deployed URL of your public landing page (e.g. https://digireps.app)
# Used in CORS allowlist
LANDING_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourapp.com